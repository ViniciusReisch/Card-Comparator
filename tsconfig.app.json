{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": ["src/app/**/*", "src/domain/**/*"]
}

