{
  "name": "card-comparator",
  "version": "0.1.0",
  "private": true,
  "description": "Local Rayquaza offer monitor for Liga Pokemon and CardTrader.",
  "scripts": {
    "dev": "concurrently -k -n API,APP -c blue,green \"npm:api:dev\" \"npm:app:dev\"",
    "api:dev": "tsx watch src/api/server.ts",
    "app:dev": "vite",
    "monitor": "tsx scripts/monitor.ts",
    "db:init": "tsx scripts/init-db.ts",
    "icons:generate": "node scripts/generate-icons.mjs",
    "playwright:install": "playwright install chromium",
    "build": "npm run build:api && npm run build:app",
    "build:api": "tsc -p tsconfig.server.json",
    "build:app": "vite build",
    "start": "node dist-api/api/server.js",
    "prod:serve": "npm run build && npm run start",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js --env production",
    "pm2:logs": "pm2 logs pokemon-rayquaza-monitor",
    "startup:install": "powershell -ExecutionPolicy Bypass -File scripts/install-windows-startup.ps1",
    "startup:remove": "powershell -ExecutionPolicy Bypass -File scripts/install-windows-startup.ps1 -Remove",
    "startup:run": "powershell -ExecutionPolicy Bypass -File scripts/start-on-login.ps1",
    "lint": "npm run lint:server && npm run lint:app",
    "lint:server": "tsc --noEmit -p tsconfig.server.json",
    "lint:app": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.54.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "pm2": "^6.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
