# === RAYQUAZA MONITOR — PRODUCAO BETA ===
NODE_ENV=production

# Servidor
PORT=3333

# Feature Flags — Beta
ENABLE_SCHEDULER=false
ENABLE_BETA_SAFE_MODE=true
ENABLE_ADMIN_DANGEROUS_ACTIONS=false
RUN_ON_BOOT=false

# Banco de dados
DATABASE_PATH=./storage/monitor.sqlite

# Scraper
HEADLESS=true
DETAIL_CONCURRENCY=1
REQUEST_DELAY_MS=6000
LIGA_MAX_VER_MAIS_CLICKS=100
CARDTRADER_MAX_PAGES=200

# MYP Cards
MYP_ENABLED=true
MYP_MAX_PAGES=50
MYP_REQUEST_DELAY_MS=1500

# Notificacoes (opcional)
NTFY_ENABLED=false
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare Tunnel
ENABLE_REMOTE_ACCESS=false
CLOUDFLARE_TUNNEL_TARGET=http://localhost:3333
CLOUDFLARE_TUNNEL_HOSTNAME=

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
